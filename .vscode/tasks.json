{
  "version": "2.0.0",
  "presentation": {
    "echo": true,
    "reveal": "always",
    "focus": false,
    "panel": "new",
    "showReuseMessage": true,
    "clear": false
  },
  "tasks": [
    {
      "label": "🐳 Start Jupyter (Docker)",
      "type": "shell",
      "command": "docker-compose -f ${workspaceFolder}/docker/docker-compose.yml up --build",
      "options": {
        "cwd": "${workspaceFolder}/docker"
      },
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "isBackground": true
    },
    {
      "label": "⏹️ Stop Jupyter (Docker)",
      "type": "shell",
      "command": "docker-compose -f ${workspaceFolder}/docker/docker-compose.yml down",
      "options": {
        "cwd": "${workspaceFolder}/docker"
      },
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "isBackground": true
    }
  ]
}